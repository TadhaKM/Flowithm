# Public — exposed to the browser. Where the FastAPI backend lives.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side only. Used by /app/api/brain/* routes to query Supabase
# directly. Copy these from the project root .env. Never commit ui/.env.local.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
