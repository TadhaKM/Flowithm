# Public — exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side only. Used by /app/api/brain/* routes to query Supabase
# directly. Copy these from the project root .env. Never commit ui/.env.local.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# FastAPI backend URL (server-side proxy routes).
FLOWITHM_API_URL=http://localhost:8000

# Guards admin proxy endpoints and POST /setup after first org.
ADMIN_TOKEN=change-me-to-a-long-random-string
BOOTSTRAP_TOKEN=
