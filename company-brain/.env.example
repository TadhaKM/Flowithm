ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Per-call timeout for Anthropic messages.create. Default 60; bump if
# generate_workflow_from_text runs long with adaptive thinking.
ANTHROPIC_TIMEOUT_SECONDS=60
VOYAGE_API_KEY=your-voyage-api-key-here
# AES-256-GCM key for encrypting third-party tokens stored in
# connected_sources.config. 32 bytes, hex-encoded (64 chars).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
# Public anon key — safe to expose to the browser. Used by the dashboard's
# Supabase Auth client (login, signup, session refresh).
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Slack bot — see slack/README.md for how to create an app and get these.
# All four are optional; the bot just won't start without them.
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-...

# Where the bot's "View full workflow" links point to (the UI host) and
# where the bot makes its POST /workflows/generate calls (the API host).
FLOWITHM_URL=http://localhost:3000
FLOWITHM_API_URL=http://localhost:8000

# Public origin of the deployed dashboard. Added to FastAPI's CORS
# allow-list alongside http://localhost:3000. Set this to your Vercel
# URL in production; leave empty for local-only.
FRONTEND_URL=

# ---------------------------------------------------------------------------
# Public Agent API (FastAPI sub-app at /api/v1) admin gate.
# ---------------------------------------------------------------------------
# Required to call /api/v1/keys (POST/GET/DELETE). Generate a long random
# string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`)
# and keep it server-only — never expose to a browser. The Next.js dashboard
# proxies key-management calls through /api/admin/* and injects this header
# server-side; the plaintext token never ships to the client.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Separate secret used ONLY to sign/verify the X-Admin-Sig header that binds
# an admin request to a specific tenant (org_id). Keep it independent from
# ADMIN_TOKEN so a leaked admin token can't be used to forge org signatures.
# Generate a DIFFERENT random value than ADMIN_TOKEN, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left empty, the system falls back to ADMIN_TOKEN for backward
# compatibility (the two secrets are then NOT independent — set this in prod).
ADMIN_SIGNING_KEY=

# Required to call POST /setup AFTER the first organisation has been
# created. Without this, an unauthenticated attacker on the public
# internet could DoS the database with synthetic organisations and mint
# session cookies. Set it to a long random string and only share it
# with whoever needs to onboard new tenants.
BOOTSTRAP_TOKEN=

# How often the scheduler fetches from every active connected source.
# Reload api/main.py for changes to take effect.
INGEST_SCHEDULE_HOURS=24

# Path to the OAuth client_secret.json downloaded from Google Cloud
# Console (Desktop OAuth client). Only used by `python -m ingest.gmail_auth`.
GOOGLE_CLIENT_SECRET_PATH=client_secret.json

# ---------------------------------------------------------------------------
# Multi-tenancy
# ---------------------------------------------------------------------------
# Default organisation for self-hosted single-tenant deploys. Used as a
# fallback when no X-Org-ID header is present on a request and as the
# scheduler's tenant when it isn't running per-org. The fixed UUID below
# matches the seed row inserted by brain/schema.sql.
ORG_ID=00000000-0000-0000-0000-000000000001

# Surfaced by GET /health. Set this in your deploy pipeline so health
# probes can confirm which build is running. Defaults to "dev".
APP_VERSION=dev

# After how many days an unreviewed skill gets the needs_review flag.
# Read at staleness-check time, no restart required.
STALE_THRESHOLD_DAYS=90

# Optional: a single Bearer key the dashboard's "Live API playground" uses
# to call /api/v1/skills/match without exposing a real customer key. Mint
# one via the dashboard's New key flow with name="Playground", then paste
# the plaintext here. Same server-only rule — never expose to the browser.
FLOWITHM_PLAYGROUND_KEY=fb_live_paste_a_minted_key_here
